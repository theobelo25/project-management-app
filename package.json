{
  "name": "project-management-app",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:migrate": "pnpm --filter database exec prisma migrate dev",
    "db:studio": "pnpm --filter database exec prisma studio",
    "db:generate": "pnpm --filter database exec prisma generate",
    "web:test": "pnpm --filter web test",
    "web:test-unit": "pnpm --filter web test:unit",
    "web:test-integration": "pnpm --filter web test:integration",
    "web:test-storybook": "pnpm --filter web test:storybook",
    "web:test-e2e": "pnpm --filter web test:e2e"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.8",
    "typescript": "^5.8.2"
  },
  "keywords": [],
