NODE_ENV=development
APP_PORT=3333
APP_HOST=0.0.0.0

FRONTEND_ORIGIN=http://localhost:3000
# Comma-separated allowed origins (must include the browser origin you use)
CORS_ORIGINS=http://localhost:3000

# Optional: share auth cookies across subdomains in production (e.g. .yourdomain.com)
# COOKIE_DOMAIN=

DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=postgres
DATASOURCE_HOST=localhost
DATASOURCE_PORT=5432
DATASOURCE_DATABASE=project_management

# PostgreSQL URL for Prisma — must match packages/database/.env (that file wins if both set).
# Default matches `docker compose up postgres` (Dockerfile.postgres + docker-compose.yml).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_management?schema=public

# Use a long random secret in production (e.g. openssl rand -base64 32)
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
REFRESH_TOKEN_EXPIRATION_MS=604800000
JWT_ISSUER=project-management-api
JWT_AUDIENCE=project-management-web
