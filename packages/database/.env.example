# Copy this file to .env in this directory (packages/database).
# Prisma CLI loads this via prisma.config.ts. The API / @repo/database also reads this
# file first so migrate and runtime use the same DATABASE_URL.
#
# Default matches local Postgres from repo root: `pnpm db:up` or `docker compose up -d postgres`.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/project_management?schema=public
